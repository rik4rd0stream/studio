{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil do usuário operacional do Rappi Commander.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["normal", "master"] },
        "notificationsEnabled": { "type": "boolean" },
        "hasRequestAccess": { "type": "boolean" }
      }
    },
    "Courier": {
      "title": "Courier",
      "type": "object",
      "description": "Dados do entregador parceiro.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "id_motoboy": { "type": "string" }
      }
    },
    "OrderRequest": {
      "title": "OrderRequest",
      "type": "object",
      "description": "Solicitação de despacho enviada entre usuários.",
      "properties": {
        "orderId": { "type": "string" },
        "storeName": { "type": "string" },
        "command": { "type": "string" },
        "targetUserId": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Perfis de usuários"
    },
    "/entregadores/{courierId}": {
      "schema": { "$ref": "#/entities/Courier" },
      "description": "Lista de motoboys"
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/OrderRequest" },
      "description": "Solicitações push"
    }
  }
}