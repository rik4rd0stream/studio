
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the Rappi Commander system, including their profile details and access role.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "notificationsEnabled": { "type": "boolean" },
        "hasRequestAccess": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "createdAt", "updatedAt"]
    },
    "OperationLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OperationLog",
      "type": "object",
      "description": "Logs system actions like copying IDs or sending 'Cheguei' commands for audit purposes.",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "rtId": { "type": "string" },
        "action": { "type": "string", "enum": ["copy_id", "cheguei"] },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "action", "userEmail", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile data."
        }
      },
      {
        "path": "/operationLogs/{logId}",
        "definition": {
          "entityName": "OperationLog",
          "schema": { "$ref": "#/backend/entities/OperationLog" },
          "description": "Historical log of actions performed in the Active Orders view."
        }
      }
    ]
  }
}
