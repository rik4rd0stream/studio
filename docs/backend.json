
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Perfil do usuário do sistema Rappi Commander.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "notificationsEnabled": { "type": "boolean" },
        "hasRequestAccess": { "type": "boolean" },
        "fcmToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "password": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "createdAt", "updatedAt"]
    },
    "OrderRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderRequest",
      "type": "object",
      "description": "Solicitação de despacho de pedido.",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "storeName": { "type": "string" },
        "command": { "type": "string" },
        "targetUserEmail": { "type": "string", "format": "email" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "unavailable"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "statusNote": { "type": "string" }
      },
      "required": ["orderId", "storeName", "command", "targetUserEmail", "senderName", "status", "createdAt"]
    },
    "OperationLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OperationLog",
      "type": "object",
      "description": "Log de auditoria das ações dos operadores.",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "rtId": { "type": "string" },
        "action": { "type": "string", "enum": ["copy_id", "cheguei"] },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "action", "userEmail", "timestamp"]
    },
    "Courier": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Courier",
      "type": "object",
      "description": "Entregador (motoboy) cadastrado no sistema.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "id_motoboy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nome", "id_motoboy"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "userProfiles": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Documentos de perfis de usuário."
    },
    "orderRequests": {
      "schema": "#/backend/entities/OrderRequest",
      "description": "Solicitações de pedidos entre operadores."
    },
    "operationLogs": {
      "schema": "#/backend/entities/OperationLog",
      "description": "Histórico de ações de auditoria."
    },
    "entregadores": {
      "schema": "#/backend/entities/Courier",
      "description": "Lista de entregadores cadastrados."
    },
    "rt_registry": {
      "schema": { "type": "object" },
      "description": "Ponte de registro de RT."
    }
  }
}
