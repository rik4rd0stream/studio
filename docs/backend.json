{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "profileType": { "type": "string", "enum": ["normal", "master"] },
        "notificationsEnabled": { "type": "boolean" },
        "hasRequestAccess": { "type": "boolean" }
      }
    },
    "Courier": {
      "title": "Courier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "id_motoboy": { "type": "string" }
      }
    },
    "OrderRequest": {
      "title": "OrderRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "storeName": { "type": "string" },
        "command": { "type": "string" },
        "targetUserId": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Profiles de usuários operacionais" },
    "/entregadores/{courierId}": { "schema": "Courier", "description": "Lista de motoboys cadastrados" },
    "/requests/{requestId}": { "schema": "OrderRequest", "description": "Solicitações de envio entre usuários" }
  }
}