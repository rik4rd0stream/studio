{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "profile": { "type": "string", "enum": ["normal", "master"] },
        "notificationsEnabled": { "type": "boolean" },
        "hasRequestAccess": { "type": "boolean" },
        "fcmToken": { "type": "string" }
      }
    },
    "Courier": {
      "title": "Courier",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "id_motoboy": { "type": "string" }
      }
    },
    "Request": {
      "title": "Request",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "storeName": { "type": "string" },
        "command": { "type": "string" },
        "targetUserId": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfis de operadores do sistema"
    },
    "/entregadores/{id}": {
      "schema": "Courier",
      "description": "Lista de motoboys cadastrados"
    },
    "/requests/{id}": {
      "schema": "Request",
      "description": "Solicitações de envio via push"
    }
  }
}
