
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Rappi Commander system with access control flags.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profile": { "type": "string", "enum": ["normal", "master"] },
        "notificationsEnabled": { "type": "boolean" },
        "hasRequestAccess": { "type": "boolean" },
        "fcmToken": { "type": "string", "description": "Token para notificações nativas Android." }
      },
      "required": ["id", "name", "email", "profile"]
    },
    "DeliveryDriver": {
      "title": "DeliveryDriver",
      "type": "object",
      "description": "Represents a delivery driver.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "id_motoboy": { "type": "string" }
      },
      "required": ["id", "nome", "id_motoboy"]
    },
    "OrderRequest": {
      "title": "OrderRequest",
      "type": "object",
      "description": "A request sent from one operator to another to dispatch an order.",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "storeName": { "type": "string" },
        "command": { "type": "string" },
        "targetUserId": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "targetUserId", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and permissions."
    },
    "/entregadores/{driverId}": {
      "schema": { "$ref": "#/backend/entities/DeliveryDriver" },
      "description": "Registered couriers."
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/OrderRequest" },
      "description": "Temporary push-like requests between users."
    }
  }
}
