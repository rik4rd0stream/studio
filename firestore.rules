rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * REGRAS SIMPLIFICADAS - ACESSO TOTAL
     * Liberado para leitura e escrita em todas as coleções.
     * Ideal para fase de testes e pequenos grupos.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}