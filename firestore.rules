
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * REGRAS DE ACESSO TOTAIS - Rappi Commander v2.4 (FORCED SYNC)
     * Permite leitura e escrita em qualquer coleção para operação sem bloqueios.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
