rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Regras de Segurança - Rappi Commander
     * Permite acesso total para usuários autenticados nas coleções operacionais.
     */

    // Perfis de Usuário (Operadores)
    match /userProfiles/{userId} {
      allow read, write: if true; 
    }

    // Banco de Entregadores (Antigo e Novo)
    match /entregadores/{id} {
      allow read, write: if true;
    }
    
    match /deliveryDrivers/{driverId} {
      allow read, write: if true;
    }

    // Pedidos e Itens
    match /orders/{orderId} {
      allow read, write: if true;
      
      match /orderItems/{orderItemId} {
        allow read, write: if true;
      }
    }

    // Solicitações de Push
    match /requests/{requestId} {
      allow read, write: if true;
    }

    // Controle de Cargos Master
    match /roles_master/{userId} {
      allow read, write: if true;
    }
    
    // Regra global para garantir que nada seja bloqueado por falta de definição
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}