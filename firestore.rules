
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * REGRAS EXPLÍCITAS - Rappi Commander v3.1
     * Forçando propagação para a nova coleção limpa.
     */
    
    match /userProfiles/{docId} {
      allow read, write: if true;
    }
    
    match /orderRequests/{docId} {
      allow read, write: if true;
    }
    
    match /operationLogs/{docId} {
      allow read, write: if true;
    }
    
    match /entregadores/{docId} {
      allow read, write: if true;
    }
    
    match /rt_registry/{docId} {
      allow read, write: if true;
    }

    // Fallback de segurança
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
