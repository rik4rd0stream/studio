rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Rappi Commander Security Rules
     * 
     * Ajustadas para permitir a fase de prototipagem e login customizado.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster() {
      // O Master é definido pelo e-mail no token ou por um registro na coleção roles_master
      return isSignedIn() && (
        request.auth.token.email == "rik4rd0stream@gmail.com" || 
        exists(/databases/$(database)/documents/roles_master/$(request.auth.uid))
      );
    }

    // Permite que qualquer usuário logado (incluindo anônimos) consulte perfis para fazer login
    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Permitido para o Ricardo configurar o banco inicial
    }

    match /deliveryDrivers/{driverId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Permitido para o Ricardo configurar o banco inicial
    }

    match /orders/{orderId} {
      allow read, write: if isSignedIn();
      
      match /orderItems/{orderItemId} {
        allow read, write: if isSignedIn();
      }
    }

    match /requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    match /roles_master/{userId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isMaster();
    }
  }
}