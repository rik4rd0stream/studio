
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * RESET TOTAL DE SEGURANÇA - v4.0
     * Liberando acesso total para depuração de nova coleção limpa.
     * Isso força a propagação das regras nos servidores do Google.
     */
    
    match /{document=**} {
      allow read, write: if true;
    }

    // Regras específicas mantidas para documentação do blueprint
    match /userProfiles/{docId} {
      allow read, write: if true;
    }
    
    match /orderRequests/{docId} {
      allow read, write: if true;
    }
    
    match /operationLogs/{docId} {
      allow read, write: if true;
    }
    
    match /entregadores/{docId} {
      allow read, write: if true;
    }
  }
}
