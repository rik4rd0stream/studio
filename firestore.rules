
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras de Emergência v4.0 - Acesso Total Recursivo
    // Isso garante que novas coleções como 'orderRequests' funcionem imediatamente
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
