
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMaster() {
      // Como estamos usando login anônimo e simulando perfis via localStorage/UI,
      // para fins de protótipo, vamos permitir leitura de perfis para usuários logados.
      // Em produção, isso checaria o campo 'profile' no documento do usuário.
      return isSignedIn();
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /entregadores/{entregadorId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /requests/{requestId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
