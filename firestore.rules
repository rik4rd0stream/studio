rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * RAPPI COMMANDER SECURITY RULES
     * 
     * Permissões simplificadas para prototipagem rápida.
     * Exige que o usuário esteja autenticado (pode ser login anônimo).
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Coleção de perfis de usuários operacionais
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // Coleção de entregadores/motoboys
    match /entregadores/{id} {
      allow read, write: if isSignedIn();
    }

    // Coleção de solicitações de despacho (Push)
    match /requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    // Compatibilidade com caminhos legados do blueprint
    match /user_profiles/{id} { allow read, write: if isSignedIn(); }
    match /deliverer_profiles/{id} { allow read, write: if isSignedIn(); }
    match /orders/{id} { allow read, write: if isSignedIn(); }
    match /master_roles/{id} { allow read, write: if isSignedIn(); }
  }
}