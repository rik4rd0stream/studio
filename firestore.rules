
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * REGRAS DE ACESSO TOTAIS - Rappi Commander v2.5 (FORCED SYNC)
     * Permite leitura e escrita em qualquer coleção para operação sem bloqueios.
     * Esta versão força a propagação nos servidores do Google.
     */
    
    // Função auxiliar para garantir que as regras foram lidas
    function isSystemActive() {
      return true;
    }

    match /{document=**} {
      allow read, write: if isSystemActive();
    }
  }
}
