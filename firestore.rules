rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * REGRAS TOTAIS - ACESSO LIVRE (MODO SIMPLIFICADO)
     * Como solicitado, as regras estão 100% abertas para evitar bloqueios no Android.
     */
    match /{document=**} {
      allow read, write: if true;
    }
  }
}