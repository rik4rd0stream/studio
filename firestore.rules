rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Rappi Commander - Regras de Segurança Simplificadas para Operação
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Coleção de Usuários (Operadores)
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // Coleção de Entregadores (Motoboys)
    match /entregadores/{id} {
      allow read, write: if isSignedIn();
    }

    // Coleção de Pedidos (Monitoramento)
    // Nota: O monitoramento do Redash é via Server Action, mas se houver cache no Firestore:
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    // Coleção de Solicitações (Push/Alertas)
    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
      allow update: if isSignedIn();
    }

    // Coleção de Papéis Administrativos
    match /roles_master/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if false; // Gerenciado apenas via Admin
    }
  }
}