rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Regras de Segurança - Rappi Commander
     * Permissões simplificadas para garantir funcionamento em Android Nativo.
     */

    // Coleção de Entregadores (Prioridade Máxima)
    match /entregadores/{document=**} {
      allow read, write: if true;
    }
    
    match /deliveryDrivers/{document=**} {
      allow read, write: if true;
    }

    // Perfis de Usuário
    match /userProfiles/{userId} {
      allow read, write: if true; 
    }

    // Pedidos e Itens
    match /orders/{orderId} {
      allow read, write: if true;
      match /orderItems/{orderItemId} {
        allow read, write: if true;
      }
    }

    // Solicitações de Push (Essencial para funcionamento no celular)
    match /requests/{requestId} {
      allow read, write: if true;
    }

    // Controle de Cargos Master
    match /roles_master/{userId} {
      allow read, write: if true;
    }
    
    // Regra global de segurança para qualquer outra coleção
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}