rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Rappi Commander Security Rules
     * 
     * Configuração para Sessão Persistente (7 dias) e Login Manual.
     * Permite consulta inicial de perfis para autenticação.
     */

    // Permite leitura pública de perfis apenas para o processo de login
    match /userProfiles/{userId} {
      allow read: if true; 
      allow write: if true; // Permitido para o Ricardo gerenciar a equipe
    }

    match /deliveryDrivers/{driverId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
      
      match /orderItems/{orderItemId} {
        allow read, write: if true;
      }
    }

    match /requests/{requestId} {
      allow read, write: if true;
    }

    match /roles_master/{userId} {
      allow read, write: if true;
    }
  }
}