
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função para verificar se o app tem o "crachá" do Firebase (Anônimo ou Logado)
    function isSignedIn() {
      return request.auth != null;
    }

    // Coleção de Usuários Operadores
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // Coleção de Entregadores (Motoboys)
    match /entregadores/{id} {
      allow read, write: if isSignedIn();
    }

    // Coleção de Solicitações de Push
    match /requests/{requestId} {
      allow read, create, delete, update: if isSignedIn();
    }

    // Bloqueio padrão para qualquer outra coisa
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
