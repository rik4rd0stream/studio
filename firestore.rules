rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funções auxiliares
    function isSignedIn() {
      return request.auth != null;
    }

    // Regras para usuários
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileType == 'master');
    }

    // Regras para entregadores (motoboys)
    match /entregadores/{courierId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Permitir para prototipagem rápida
    }

    // Regras para solicitações push (requests)
    match /requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    // Regras para pedidos (opcional, se usar coleção orders)
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }
  }
}